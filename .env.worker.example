MINISAGO_BRIDGE_URL=wss://bot.hsichen.dev/api/mac-agent/ws
MINISAGO_MAC_BRIDGE_SECRET=replace-with-the-same-32-byte-or-longer-secret
MINISAGO_MAX_CONCURRENT_JOBS=2
# Compose overrides IDs and capabilities to keep read and write credentials in separate containers.
MINISAGO_WORKER_ID=oracle-read
MINISAGO_WORKER_CAPABILITIES=chat,dev-read
MINISAGO_WORKER_PRIORITY=100
MINISAGO_GITHUB_REPOSITORIES=owner/repository
MINISAGO_GITHUB_READ_CONFIG_DIR=/home/bun/.config/gh-read
MINISAGO_GITHUB_WRITE_CONFIG_DIR=/home/bun/.config/gh-write
MINISAGO_GITHUB_WORKTREE_ROOT=/workspace/worktrees
