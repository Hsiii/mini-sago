{
  "name": "minisago",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "deploy": "bun scripts/deploy.mjs",
    "release": "bun run deploy && bun run worker:update",
    "build": "tsc --noEmit",
    "start": "bun src/server.ts",
    "test": "bun test",
    "lint": "tsc --noEmit",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "fetch:vocab": "bun scripts/fetch-wiktionary-vocab.mjs",
    "publish:panel": "bun --env-file=.env.local scripts/publish-channel-panel.mjs",
    "register:commands": "bun --env-file=.env.local scripts/register-commands.mjs",
    "sync:install": "bun --env-file=.env.local scripts/sync-install-settings.mjs",
    "mac-agent:install": "bun --env-file=.env.local scripts/mac-agent.mjs install",
    "mac-agent:status": "bun scripts/mac-agent.mjs status",
    "mac-agent:uninstall": "bun scripts/mac-agent.mjs uninstall",
    "worker:update": "bun run mac-agent:install"
  },
  "dependencies": {
    "tweetnacl": "1.0.3"
  },
  "devDependencies": {
    "@types/node": "22.15.30",
    "bun-types": "1.3.4",
    "prettier": "^3.8.4",
    "typescript": "5.8.3"
  },
  "trustedDependencies": [
    "tweetnacl"
  ]
}
